{
  "id": "freecut",
  "name": "FreeCut",
  "version": "0.1.0",
  "description": "GPU-accelerated video editor with multi-track timeline, effects, and native export.",
  "icon": "clapperboard",
  "route": "freecut",
  "entry": "index.html",
  "type": "plugin",
  "autostart": false,
  "scopes": ["storage.read", "storage.write"],
  "sandbox": {
    "python": "3.11",
    "venv": "env",
    "env": {
      "API_HOST": "127.0.0.1"
    }
  },
  "install": {
    "steps": [{ "run": "bash build.sh" }, { "pip": "requirements.txt" }]
  },
  "start": {
    "command": "python -m uvicorn main:app --host 127.0.0.1 --port __PORT__ --app-dir ./upstream/backend",
    "daemon": true,
    "ready_pattern": "Uvicorn running on",
    "port": "auto"
  }
}
