{
  "id": "counter",
  "name": "Counter (Demo)",
  "version": "2.0.0",
  "description": "Official demo — full-stack plugin with Python backend, Gradio UI, FastAPI REST API, and persistent state.",
  "icon": "hash",
  "route": "counter",
  "entry": "index.html",
  "type": "plugin",
  "autostart": false,
  "scopes": ["storage.read", "storage.write", "host.open_chat"],
  "sandbox": {
    "python": "3.11",
    "venv": "env",
    "env": {
      "GRADIO_SERVER_NAME": "127.0.0.1"
    }
  },
  "install": {
    "steps": [
      { "pip": "requirements.txt" }
    ]
  },
  "start": {
    "command": "python server.py --host 127.0.0.1 --port __PORT__",
    "daemon": true,
    "ready_pattern": "Uvicorn running on",
    "port": "auto"
  }
}
